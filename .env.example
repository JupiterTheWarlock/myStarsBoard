# GitHub Configuration
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_USERNAME=your_github_username_here

# OpenAI / AI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Tag Generation Settings
LANGUAGE=zh  # Language for generated tags: en (English) or zh (Chinese)
TAG_COUNT_MIN=3
TAG_COUNT_MAX=5
ENABLE_NEW_TAGS=true
ENABLE_THINKING=false

# Processing Settings
BATCH_SIZE=5

# WebUI Configuration
# STARSBOARD_TITLE=My Stars
# STARSBOARD_FAVICON=⭐

# Vercel Deployment (for semantic search)
# Same OPENAI_API_KEY and OPENAI_BASE_URL need to be configured in Vercel Environment Variables
# Embedding model: qwen/qwen3-embedding-8b (256-dim Matryoshka)
